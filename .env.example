# Local development only.
# Copy this file to .env and replace the password before running docker compose.

MONY_HOST=127.0.0.1
MONY_PORT=3000
MONY_AUTH_ISSUER=mony
MONY_AUTH_AUDIENCE=mony-api
MONY_AUTH_JWT_PRIVATE_KEY_PATH=.local/keys/mony-jwt-private.pem
MONY_AUTH_JWT_PUBLIC_KEY_PATH=.local/keys/mony-jwt-public.pem
MONY_AUTH_ACCESS_TOKEN_TTL_SECONDS=600
MONY_AUTH_REFRESH_TOKEN_TTL_DAYS=30
MONY_AUTH_SECURE_COOKIES=false
MONY_AUTH_WEBAUTHN_RP_ID=localhost
MONY_AUTH_WEBAUTHN_RP_ORIGIN=http://localhost
MONY_AUTH_WEBAUTHN_RP_NAME=mony
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=mony
POSTGRES_USER=mony_app
POSTGRES_PASSWORD=change-me-with-a-long-random-password
